{
  "name": "@quran-reader/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm --workspace @quran-reader/quran-data run data:validate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "npm --workspace @quran-reader/quran-data run build && npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@quran-reader/quran-data": "0.1.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
